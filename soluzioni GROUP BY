1. SELECT count(*) AS iscritti, YEAR(enrolment_date)
FROM students
GROUP BY YEAR(enrolment_date);

2. SELECT count(*) AS stesso_edificio, office_address
FROM teachers
GROUP BY office_address

3. SELECT AVG(vote) AS media_voti, exam_id AS appello
FROM exam_student
GROUP BY exam_id

4. SELECT count(*) AS numero_corsi,  department_id
FROM degrees
GROUP BY department_id


